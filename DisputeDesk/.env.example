# ── Shopify ──────────────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_orders,read_shopify_payments_disputes,write_shopify_payments_dispute_evidences
SHOPIFY_APP_URL=https://your-app.vercel.app

# Pin GraphQL Admin API version (default 2026-01)
SHOPIFY_API_VERSION=2026-01

# ── Supabase (server-only — never expose anon key to client) ─
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Token Encryption (AES-256-GCM) ─────────────────────
# V1 key (hex-encoded 32-byte key). Add V2, V3… for rotation.
TOKEN_ENCRYPTION_KEY_V1=
# Backward-compat alias — points to same value as V1
TOKEN_ENCRYPTION_KEY=${TOKEN_ENCRYPTION_KEY_V1}

# ── Jobs / Cron ─────────────────────────────────────────
# Shared secret for cron → worker endpoint auth
CRON_SECRET=

# ── Observability ────────────────────────────────────────
# SENTRY_DSN=
# LOG_LEVEL=info
